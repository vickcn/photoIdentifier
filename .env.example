# 🛡️ Photo Identifier 環境變數範本
# 請複製此檔案並更名為 .env 進行設定

# --- [AI 核心設定] ---
# Google Cloud Vertex AI API Key
VERTEX_API_KEY=your_vertex_api_key_here

# --- [FastAPI 安全性] ---
# Session 加密金鑰 (請輸入一段長隨機字串)
SESSION_SECRET=yoursecretkeyhere_random_string

# --- [Google Drive OAuth 設定] ---
# 取得方式: Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# 回導網址 (本地測試請用 http://localhost:8000/auth/callback)
# 部署到 Vercel 時需改為 https://your-app.vercel.app/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# --- [進階設定 (選擇性)] ---
# 指定 Token 儲存路徑
DRIVE_TOKEN_DIR=.secrets/drive_tokens
